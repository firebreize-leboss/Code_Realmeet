  classDef payment fill:#EF4444,stroke:#DC2626,color:#fff,stroke-width:2px
  classDef plusone fill:#EC4899,stroke:#DB2777,color:#fff,stroke-width:2px
  classDef checkin fill:#14B8A6,stroke:#0D9488,color:#fff,stroke-width:2px
  classDef messaging fill:#3B82F6,stroke:#2563EB,color:#fff,stroke-width:2px
  classDef social fill:#A855F7,stroke:#9333EA,color:#fff,stroke-width:2px
  classDef notif fill:#F97316,stroke:#EA580C,color:#fff,stroke-width:2px
  classDef business fill:#64748B,stroke:#475569,color:#fff,stroke-width:2px

  classDef wip fill:#422006,stroke:#92400E,color:#FBBF24,stroke-width:1px,stroke-dasharray:5 3
  classDef planned fill:#1E293B,stroke:#475569,color:#94A3B8,stroke-width:1px,stroke-dasharray:3 3

  %% ============================================================
  %% 🔐 AUTHENTIFICATION
  %% ============================================================
  AUTH[🔐 Authentification]:::auth
  AUTH --- AUTH_F1[✅ Inscription utilisateur]:::feat
  AUTH --- AUTH_F2[✅ Inscription entreprise]:::feat
  AUTH --- AUTH_F3[✅ Login email / password]:::feat
  AUTH --- AUTH_F4[🔜 OAuth · Apple · Google]:::planned
  AUTH --- AUTH_F5[✅ Gestion session Supabase]:::feat
  AUTH --- AUTH_F6[✅ Profil obligatoire post-signup]:::feat

  %% ============================================================
  %% 👤 PROFIL
  %% ============================================================
  PROFILE[👤 Profil]:::profile
  PROFILE --- PROF_F1[✅ Édition profil · nom · bio · avatar]:::feat
  PROFILE --- PROF_F2[✅ Centres d'intérêt]:::feat
  PROFILE --- PROF_F3[✅ Username unique]:::feat
  PROFILE --- PROF_F4[✅ Ville / Localisation]:::feat
  PROFILE --- PROF_F5[✅ Type de compte · user / business]:::feat
  PROFILE --- PROF_F6[✅ Push token · expo_push_token]:::feat

  %% ============================================================
  %% 🎯 ACTIVITÉS
  %% ============================================================
  ACTIVITIES[🎯 Activités]:::activities
  ACTIVITIES --- ACT_F1[✅ Création d'activité · host]:::feat
  ACTIVITIES --- ACT_F2[✅ Catégories & filtres]:::feat
  ACTIVITIES --- ACT_F3[✅ Créneaux · activity_slots]:::feat
  ACTIVITIES --- ACT_F4[✅ Inscription à un créneau]:::feat
  ACTIVITIES --- ACT_F5[✅ Désinscription · soft delete]:::feat
  ACTIVITIES --- ACT_F6[✅ Carte MapLibre · browse]:::feat
  ACTIVITIES --- ACT_F7[✅ Annulation par l'hôte]:::feat
  ACTIVITIES --- ACT_F8[✅ Capacité max par créneau]:::feat


flowchart TB

  %% ============================================================
  %% STYLES
  %% ============================================================
  classDef auth fill:#6366F1,stroke:#4F46E5,color:#fff,stroke-width:2px
  classDef profile fill:#8B5CF6,stroke:#7C3AED,color:#fff,stroke-width:2px
  classDef activities fill:#F59E0B,stroke:#D97706,color:#000,stroke-width:2px
